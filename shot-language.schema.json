{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.video-pipeline/shot-language.schema.json",
  "title": "Video Pipeline Shot Card",
  "type": "object",
  "additionalProperties": true,
  "required": ["type", "id", "start", "end", "intent", "primary", "layout", "focus", "beats"],
  "properties": {
    "type": { "const": "shot" },
    "id": { "type": "string", "minLength": 1 },
    "start": { "type": "number", "minimum": 0 },
    "end": { "type": "number", "exclusiveMinimum": 0 },
    "anchor": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["start"],
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" }
          }
        }
      ]
    },
    "intent": {
      "enum": ["presenter", "explain", "evidence", "compare", "process", "conclusion", "breather", "chapter"]
    },
    "primary": {
      "enum": ["presenter", "screen", "document", "image", "video", "diagram", "text", "data"]
    },
    "layout": {
      "enum": ["L01", "L02", "L03", "L04", "L05", "L06", "L07", "L08", "L09", "L10", "L11", "L12", "L13"]
    },
    "focus": { "type": "string", "minLength": 1 },
    "presenter": {
      "type": "object",
      "properties": {
        "form": { "enum": ["original", "window", "avatar", "cutout", "background", "hidden"] },
        "placement": {
          "enum": ["top-left", "top-center", "top-right", "center-left", "center", "center-right", "bottom-left", "bottom-center", "bottom-right"]
        },
        "widthPct": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "cornerRadiusPx": { "type": "number", "minimum": 0 },
        "dimOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "cutoutPrefix": { "type": "string" },
        "cutoutFromSec": { "type": "number", "minimum": 0 },
        "cutoutCount": { "type": "integer", "minimum": 1 }
      }
    },
    "media": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "src"],
        "properties": {
          "id": { "type": "string" },
          "src": { "type": "string" },
          "kind": { "enum": ["image", "video"] },
          "label": { "type": "string" },
          "role": { "enum": ["primary", "support", "evidence"] },
          "atSec": { "type": "number", "minimum": 0 },
          "trimFromSec": { "type": "number", "minimum": 0 },
          "fit": { "enum": ["contain", "cover"] },
          "surface": { "enum": ["bare", "framed", "paper", "sticker"] }
        }
      }
    },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["atSec", "action", "target"],
        "properties": {
          "atSec": { "type": "number", "minimum": 0 },
          "action": { "enum": ["show", "focus", "highlight", "dim", "hide", "promote"] },
          "target": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
